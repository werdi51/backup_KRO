<Window x:Class="AutoSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoSaver"
        mc:Ignorable="d"
        Title="Настройка авторезервирования" Height="750" Width="500"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Конфигурация бэкапа" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Сетевая папка (Источник):" Margin="0,0,0,5" Foreground="#555"/>
            <DockPanel>
                <Button x:Name="BtnBrowseSource" Content="Обзор..." DockPanel.Dock="Right" Width="80" Margin="10,0,0,0" Click="BtnBrowseSource_Click"/>
                <TextBox x:Name="TxtSourcePath" Padding="5" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Папка бэкапов (Назначение):" Margin="0,0,0,5" Foreground="#555"/>
            <DockPanel>
                <Button x:Name="BtnBrowseDest" Content="Обзор..." DockPanel.Dock="Right" Width="80" Margin="10,0,0,0" Click="BtnBrowseDest_Click"/>
                <TextBox x:Name="TxtDestPath" Padding="5" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>
        <Border Grid.Row="3" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Margin="0,10">
            <TextBox x:Name="TxtStatus" 
             Text="Программа готова к работе" 
             IsReadOnly="True" 
             TextWrapping="Wrap" 
             VerticalScrollBarVisibility="Auto" 
             BorderThickness="0" 
             Background="Transparent"
             AcceptsReturn="True"/>
        </Border>

        <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="TxtFileCount" Text="Файлов: 0 / 0" Foreground="#666" FontSize="11"/>
                <TextBlock x:Name="TxtSizeProgress" Text="0.00 ГБ / 0.00 ГБ" DockPanel.Dock="Right" Foreground="#666" FontSize="11"/>
            </DockPanel>

            <ProgressBar x:Name="PrgBar" Height="12" Minimum="0" Maximum="100" Margin="0,5,0,0" Foreground="#0288D1"/>

            <DockPanel LastChildFill="False" Margin="0,5,0,0">
                <TextBlock x:Name="TxtPercent" Text="0%" FontWeight="Bold" Foreground="#0288D1"/>
                <TextBlock x:Name="TxtSpeed" Text="0 МБ/с" Margin="20,0,0,0" Foreground="#43A047"/>
                <TextBlock x:Name="TxtTimer" Text="00:00:00" DockPanel.Dock="Right" Foreground="#666"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="Сохранить настройки" Width="140" Height="30" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnRunNow" Content="Запустить сейчас" Width="120" Height="30" Background="#E1F5FE" Click="BtnRunNow_Click"/>
        </StackPanel>

    </Grid>
</Window>
